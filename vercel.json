{
  "buildCommand": "cd frontend && CI=false npm install && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_MAPBOX_ACCESS_TOKEN": "${REACT_APP_MAPBOX_ACCESS_TOKEN}"
  }
}
