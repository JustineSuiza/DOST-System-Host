{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "buildCommand": "CI=false npm --prefix frontend install && CI=false npm --prefix frontend run build",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_MAPBOX_ACCESS_TOKEN": "${REACT_APP_MAPBOX_ACCESS_TOKEN}"
  }
}
